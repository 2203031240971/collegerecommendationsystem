# ═══════════════════════════════════════════════════════════════
# EduMatch Configuration
# ═══════════════════════════════════════════════════════════════

# ── College Search Mode ─────────────────────────────────────────
# Set to 'true' to search real colleges from internet
# Set to 'false' to use hardcoded colleges.json
USE_REAL_COLLEGE_SEARCH=false

# ── Google Custom Search API (Required for real search) ──────────
# Get these from: https://console.cloud.google.com
GOOGLE_SEARCH_API_KEY=your_google_api_key_here
CUSTOM_SEARCH_ENGINE_ID=your_search_engine_cx_here

# ── Google Gemini API (For AI Chat) ─────────────────────────────
# Get API key from: https://ai.google.dev/
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# ── Backend Settings ────────────────────────────────────────────
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
ENVIRONMENT=development

# ═══════════════════════════════════════════════════════════════
# QUICK START GUIDE:
# ═══════════════════════════════════════════════════════════════
#
# 1. OPTION A: Use Hardcoded Database (Fast, No Setup)
#    - Leave USE_REAL_COLLEGE_SEARCH=false
#    - Uses colleges.json (50 colleges from major cities)
#    - Works immediately, no API key needed
#
# 2. OPTION B: Use Real Internet Search (Recommended)
#    - Set USE_REAL_COLLEGE_SEARCH=true
#    - Set up Google Custom Search API:
#      a) Go to https://console.cloud.google.com
#      b) Create API Credentials (API Key)
#      c) Enable Custom Search API
#      d) Go to https://cse.google.com
#      e) Create search engine for entire web
#      f) Copy API Key and Search Engine ID (cx)
#    - Paste them in this file
#    - Restart server
#
# 3. For Gemini AI Chat (Optional)
#    - Go to https://ai.google.dev
#    - Create API key
#    - Add to this file
#
# ═══════════════════════════════════════════════════════════════
